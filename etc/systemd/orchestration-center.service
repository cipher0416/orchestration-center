[Unit]
Description=Orchestration Center - A2A-T Orchestration Center Service
Documentation=https://github.com/your-org/registry-center
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/orchestration-center
Environment="APP_USER=root"
Environment="APP_UID=0"
Environment="APP_GID=0"
Environment="OPENSSL_CONF=/opt/orchestration-center/etc/conf/custom_openssl.cnf"
ExecStart=/usr/bin/python -m orchestrate.start
ExecStop=/bin/kill -15 $MAINPID
Restart=on-failure
RestartSec=5s
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target